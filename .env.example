# # =============================================================================
# # Zoya AI Employee — .env.example
# # Copy to .env and fill in real values. NEVER commit .env to git.
# # =============================================================================

# # ---------------------------------------------------------------------------
# # AI Provider: "claude" | "qwen" | "ollama"
# # ---------------------------------------------------------------------------
# AI_PROVIDER=claude

# # Ollama (local, free)
# OLLAMA_MODEL=qwen3:4b
# OLLAMA_BASE_URL=http://localhost:11434/v1

# # Qwen via DashScope
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# QWEN_MODEL=qwen-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# # ---------------------------------------------------------------------------
# # Gmail / Google OAuth2
# # ---------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REFRESH_TOKEN=your_google_refresh_token
# GMAIL_POLL_INTERVAL=60           # seconds between inbox polls
# GMAIL_MAX_RESULTS=10             # max emails per poll

# # ---------------------------------------------------------------------------
# # WhatsApp Business API (Meta Cloud API)
# # ---------------------------------------------------------------------------
# WHATSAPP_ACCESS_TOKEN=your_whatsapp_permanent_access_token
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
# WHATSAPP_VERIFY_TOKEN=zoya_verify_token   # must match webhook config
# WHATSAPP_PORT=5001
# WHATSAPP_DRY_RUN=true                     # set false to send real messages

# # Owner WhatsApp number for briefing delivery (E.164 format)
# OWNER_WHATSAPP_NUMBER=447911123456

# # ---------------------------------------------------------------------------
# # Twitter / X API v2 (OAuth 1.0a)
# # ---------------------------------------------------------------------------
# TWITTER_API_KEY=your_twitter_api_key
# TWITTER_API_SECRET=your_twitter_api_secret
# TWITTER_ACCESS_TOKEN=your_twitter_access_token
# TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret
# TWITTER_BEARER_TOKEN=your_twitter_bearer_token   # read-only timeline/metrics
# TWITTER_DRY_RUN=true                             # set false to post live

# # ---------------------------------------------------------------------------
# # LinkedIn API (OAuth 2.0)
# # ---------------------------------------------------------------------------
# LINKEDIN_CLIENT_ID=your_linkedin_client_id
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
# LINKEDIN_PAGE_ID=your_linkedin_page_or_person_id
# LINKEDIN_DRY_RUN=true


# # ---------------------------------------------------------------------------
# # Odoo ERP (REST API)
# # ---------------------------------------------------------------------------
# ODOO_URL=https://your-company.odoo.com
# ODOO_DB=your_database_name
# ODOO_USERNAME=your_odoo_username
# ODOO_API_KEY=your_odoo_api_key
# ODOO_DRY_RUN=true

# # ---------------------------------------------------------------------------
# # Error Recovery
# # ---------------------------------------------------------------------------
# MAX_RETRIES=3                   # Orchestrator file retries before quarantine
# STUCK_TASK_THRESHOLD_MIN=20     # Minutes before Ralph rescues In_Progress tasks

# # ---------------------------------------------------------------------------
# # Rate Limiting (requests per minute per service)
# # ---------------------------------------------------------------------------
# TWITTER_RATE_LIMIT_RPM=15
# LINKEDIN_RATE_LIMIT_RPM=30
# META_RATE_LIMIT_RPM=60
# WHATSAPP_RATE_LIMIT_RPM=80

# # ---------------------------------------------------------------------------
# # WhatsApp Watcher (Playwright-based local monitoring)
# # ---------------------------------------------------------------------------
# WHATSAPP_WATCHER_SESSION_PATH=./whatsapp_session
# WHATSAPP_WATCHER_KEYWORDS=urgent,asap,invoice,payment,help,price,order,meeting,call me,contract
# WHATSAPP_WATCHER_CHECK_INTERVAL=30
# WHATSAPP_WATCHER_BROWSER_HEADLESS=true
# WHATSAPP_WATCHER_BROWSER_TIMEOUT=60
# WHATSAPP_WATCHER_DRY_RUN=false
# WHATSAPP_WATCHER_LOG_LEVEL=INFO

# # ---------------------------------------------------------------------------
# # LinkedIn Automation (Playwright-based, Human-in-the-Loop)
# # ---------------------------------------------------------------------------
# LINKEDIN_SESSION_PATH=./linkedin_session                    # Browser session storage
# LINKEDIN_CHECK_INTERVAL_DM=7200                             # Check DMs every 2 hours (seconds)
# LINKEDIN_CHECK_INTERVAL_COMMENTS=10800                      # Check comments every 3 hours (seconds)
# LINKEDIN_CHECK_INTERVAL_VISITORS=86400                      # Check profile visitors daily (seconds)
# LINKEDIN_MAX_DAILY_ACTIONS=10                               # Safety limit: max 10 actions/day
# LINKEDIN_RUN_START_HOUR=8                                   # Only run between these hours (8 AM)
# LINKEDIN_RUN_END_HOUR=20                                    # (8 PM) - avoid detection
# LINKEDIN_TARGET_INDUSTRIES=Business,Entrepreneurship,Leadership  # For lead scoring
# LINKEDIN_HASHTAGS=#Business #Entrepreneurship #Leadership #Innovation
# LINKEDIN_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
# LINKEDIN_BROWSER_HEADLESS=true                              # Run headless mode (faster)
# LINKEDIN_BROWSER_TIMEOUT=60                                 # Page load timeout (seconds)
# LINKEDIN_DRY_RUN=false                                      # Test mode: log without acting
# LINKEDIN_LOG_LEVEL=INFO                                     # DEBUG, INFO, WARNING, ERROR
# LINKEDIN_ENABLE_ANTI_DETECTION=true                         # Random delays, user agent spoofing
