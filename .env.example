# Environment Variables Configuration
# Date: 2026-03-05
# Zoya - Personal AI Employee Automation
#
# Copy this file to .env and fill in your actual credentials
# ⚠️  NEVER commit .env to git - add to .gitignore

# ================================================================================
# GMAIL AUTOMATION (IMAP/SMTP with App Password)
# ================================================================================
#
# Required for: Email sending, reading, searching, organizing
#
# SETUP INSTRUCTIONS:
# 1. Go to https://myaccount.google.com/
# 2. Click "Security" in left menu
# 3. Enable 2-Factor Authentication (if not already enabled)
# 4. Scroll down to "App passwords"
# 5. Select "Mail" and "Windows Computer" (or your device)
# 6. Google generates 16-character password (format: xxxx xxxx xxxx xxxx)
# 7. Copy it (you won't see it again)
# 8. Paste below
#
# ⚠️  This is NOT your regular Gmail password
# ⚠️  This is a special password for apps only
# ⚠️  You can revoke it anytime from Google Account settings

GMAIL_EMAIL="your-email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Example (DO NOT USE):
# GMAIL_EMAIL="john.doe@gmail.com"
# GMAIL_APP_PASSWORD="abcd efgh ijkl mnop"


# ================================================================================
# WHATSAPP AUTOMATION (Playwright - Local Browser)
# ================================================================================
#
# Required for: Sending messages, media, broadcasts
#
# SETUP INSTRUCTIONS:
# 1. Run QR login once: python -m src.automations.whatsapp_playwright
# 2. Scan QR code with your phone's WhatsApp app
# 3. Session automatically saved to ~/.whatsapp_session/state.json
# 4. No credentials needed in .env!
#
# OPTIONAL SETTINGS:
# - WHATSAPP_HEADLESS: Run browser headless (faster)
# - WHATSAPP_TIMEOUT: Page load timeout in ms

WHATSAPP_HEADLESS="true"
# WHATSAPP_TIMEOUT="30000"

# Note: WhatsApp session is LOCAL only
# - Session file: ~/.whatsapp_session/state.json
# - No passwords stored
# - No API keys needed
# - Works with personal WhatsApp account


# ================================================================================
# LINKEDIN AUTOMATION (Playwright - Local Browser)
# ================================================================================
#
# Required for: Posting, messaging, engagement
#
# SETUP INSTRUCTIONS:
# 1. Create LinkedIn account or use existing
# 2. Add email and password below
# 3. First run will authenticate and save session
# 4. Session saved to ~/.linkedin_session/state.json
#
# ⚠️  Use a dedicated account if possible
# ⚠️  LinkedIn may ask for 2FA on first login

LINKEDIN_EMAIL="your-email@example.com"
LINKEDIN_PASSWORD="your-password"

# Example (DO NOT USE):
# LINKEDIN_EMAIL="john.doe@linkedin.com"
# LINKEDIN_PASSWORD="securePassword123!"

# Note: LinkedIn session is LOCAL
# - Session file: ~/.linkedin_session/state.json
# - Password used only for initial login
# - Subsequent logins use cached session


# ================================================================================
# ORCHESTRATOR SETTINGS
# ================================================================================

# AI Provider: claude | qwen | ollama
AI_PROVIDER="claude"

# Orchestrator polling interval (seconds)
ORCHESTRATOR_POLL_INTERVAL="30"

# Maximum retries for failed tasks
MAX_RETRIES="3"

# Batch size for processing
MAX_BATCH_SIZE="5"


# ================================================================================
# OPTIONAL: Cloud AI Providers
# ================================================================================

# For Claude Code CLI integration
CLAUDECODE_API_KEY=""

# For Qwen/DashScope API
DASHSCOPE_API_KEY=""
QWEN_MODEL="qwen-plus"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# For Ollama (local)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="mistral"


# ================================================================================
# SUMMARY
# ================================================================================
#
# WHAT YOU MUST SET:
# ✅ GMAIL_EMAIL + GMAIL_APP_PASSWORD (for email automation)
# ✅ LINKEDIN_EMAIL + LINKEDIN_PASSWORD (for LinkedIn automation)
# ✅ Run WhatsApp login once (no .env credentials needed)
#
# WHAT YOU CAN SKIP:
# ⭕ Cloud AI providers (if using local orchestrator)
# ⭕ Advanced settings (defaults work fine)
#
# QUICK TEST:
# export GMAIL_EMAIL="your-email@gmail.com"
# export GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
# export LINKEDIN_EMAIL="your-email@example.com"
# export LINKEDIN_PASSWORD="your-password"
# python src/orchestrator.py
#
# ================================================================================
